GROQ__API_KEY=


OPENAI_API_KEY=

# Application Settings
DEBUG=true
ENVIRONMENT=development

# PostgreSQL Database
POSTGRES_DATABASE_URL=postgresql+psycopg2://<user>:<password>@postgres:5432/<database>

# External Services
OPENSEARCH_HOST=http://opensearch:9200
OPENSEARCH__HOST=http://opensearch:9200
OLLAMA_HOST=http://host.docker.internal:11434

# OpenSearch Configuration (Single hybrid index for all search types)
OPENSEARCH__INDEX_NAME=nuke-docs
OPENSEARCH__CHUNK_INDEX_SUFFIX=chunks
OPENSEARCH__MAX_TEXT_SIZE=1000000

# Vector Search Settings
OPENSEARCH__VECTOR_DIMENSION=1024
OPENSEARCH__VECTOR_SPACE_TYPE=cosinesimil

# Hybrid Search Settings  
OPENSEARCH__RRF_PIPELINE_NAME=hybrid-rrf-pipeline
OPENSEARCH__HYBRID_SEARCH_SIZE_MULTIPLIER=2

# Text Chunking Configuration
CHUNKING__CHUNK_SIZE=600
CHUNKING__OVERLAP_SIZE=100
CHUNKING__MIN_CHUNK_SIZE=100
CHUNKING__SECTION_BASED=true

# Jina AI Embeddings (Required for hybrid search)
JINA_API_KEY=

# Ray indexing tuning for Airflow/K8s workers.
# Keep embedding concurrency low unless the worker has enough RAM for multiple
# embedding clients or local fallback models.
RAG_RAY_OBJECT_STORE_MEMORY_BYTES=500000000
RAG_RAY_EMBED_BATCH_SIZE=32
RAG_RAY_EMBED_CONCURRENCY=1
RAG_RAY_EMBED_NUM_CPUS=2
RAG_RAY_BULK_BATCH_SIZE=200
RAG_RAY_BULK_CONCURRENCY=1
RAG_RAY_BULK_NUM_CPUS=1
# Optional Ray memory monitor overrides. Example: 0.98 raises Ray's kill threshold.
RAG_RAY_MEMORY_USAGE_THRESHOLD=
RAG_RAY_MEMORY_MONITOR_REFRESH_MS=

# Ollama Configuration
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT=300

# Safety guardrail configuration.
# Local docker-compose does not pull an Ollama Llama Guard model automatically.
# To enable this, run: ollama pull llama-guard
GUARDRAILS__LLAMA_GUARD_ENABLED=false
GUARDRAILS__LLAMA_GUARD_MODEL=llama-guard
GUARDRAILS__LLAMA_GUARD_FAIL_CLOSED_INPUT=true
GUARDRAILS__LLAMA_GUARD_FAIL_CLOSED_OUTPUT=true

# Langfuse v3 Tracing Configuration - Official SDK Standard (single underscore)
LANGFUSE_ENABLED=true
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
# LANGFUSE__BASE_URL="https://cloud.langfuse.com"
# LANGFUSE_PUBLIC_KEY=<langfuse-public-key>
# LANGFUSE_SECRET_KEY=<langfuse-secret-key>
LANGFUSE_FLUSH_AT=15
LANGFUSE_FLUSH_INTERVAL=1.0
LANGFUSE_DEBUG=true

# Langfuse Server Configuration (for docker-compose)
# WARNING: Change these values in production! These are development defaults.
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
# REQUIRED: Generate a real 64-character hex key before starting: openssl rand -hex 32
LANGFUSE_ENCRYPTION_KEY=
LANGFUSE_REDIS_PASSWORD=
LANGFUSE_MINIO_ACCESS_KEY=
LANGFUSE_MINIO_SECRET_KEY=

# Redis Cache Configuration
REDIS__HOST=redis
REDIS__PORT=6379
# Leave empty since compose.yml Redis has no --requirepass configured
REDIS__PASSWORD=
REDIS__DB=0
REDIS__TTL_HOURS=6

# Airflow Settings
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=true
AIRFLOW__HOME=/opt/airflow
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://<user>:<password>@postgres:5432/<database>

HF_TOKEN=
# Dagster orchestrator
DAGSTER_POSTGRES_URL=postgresql+psycopg2://<user>:<password>@postgres:5432/<database>
NEO4J__ENABLED=true
NEO4J__HOST=neo4j
NEO4J__PORT=7687
NEO4J__USER=neo4j
NEO4J__PASSWORD=


ALERTMANAGER_SLACK_WEBHOOK_URL=<slack-webhook-url>
