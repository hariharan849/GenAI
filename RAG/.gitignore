# Airflow runtime directories (prevent re-accumulation at root)
# Anchored to RAG/ root with leading / to avoid matching deep dirs
/dags/
/logs/
/plugins/
/config/

# Airflow internal runtime dirs — wildcard covers both pre- and post-move paths
**/airflow/airflow/
**/airflow/src/

# Gstack planning artifacts
PLAN*.md
PLAN-*.md

# Terraform — never commit layer state files or provider cache
infra/terraform/**/.terraform/
infra/terraform/**/.terraform.lock.hcl
infra/terraform/layers/**/*.tfstate
infra/terraform/layers/**/*.tfstate.backup
infra/terraform/layers/**/terraform.tfvars
# bootstrap state IS committed (resource IDs only, no secrets)
!infra/terraform/bootstrap/terraform.tfstate

# Next.js build output — large binary caches exceed GitHub's 100 MB limit
ui/.next/
